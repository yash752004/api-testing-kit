{
  "name": "api-testing-kit",
  "private": true,
  "packageManager": "bun@1.2.19",
  "scripts": {
    "dev": "bun run dev:web",
    "build": "bun run build:web",
    "preview": "bun run preview:web",
    "lint": "bun run lint:web",
    "typecheck": "bun run typecheck:web && bun run typecheck:server",
    "check": "bun run typecheck",
    "dev:web": "bun run --cwd ./apps/web dev",
    "build:web": "bun run --cwd ./apps/web build",
    "preview:web": "bun run --cwd ./apps/web preview",
    "check:web": "bun run --cwd ./apps/web check",
    "lint:web": "bun run --cwd ./apps/web lint",
    "typecheck:web": "bun run --cwd ./apps/web typecheck",
    "test:web": "bun run --cwd ./apps/web test",
    "test:web:unit": "bun run --cwd ./apps/web test:unit -- --run",
    "test:web:smoke": "bun run --cwd ./apps/web test:smoke",
    "test:web:e2e": "bun run --cwd ./apps/web test:e2e",
    "dev:server": "go -C ./server run ./cmd/api",
    "lint:server": "go -C ./server vet ./...",
    "typecheck:server": "go -C ./server test -run '^$' ./...",
    "test:server": "go -C ./server test ./...",
    "test:server:integration": "go -C ./server test ./tests/integration/...",
    "fmt:server": "gofmt -w ./server/cmd ./server/internal",
    "test": "bun run test:web && bun run test:server"
  }
}
